# Firebase Configuration (use environment variables instead of hardcoding in code)
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_auth_domain
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_storage_bucket
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Links to other apps
VITE_HK_WEB_APP_URL=https://your-hk-web-app-url
VITE_HK_ANDROID_APP_URL=https://your-hk-android-download-url

VITE_WENNZE_WEB_APP_URL=https://your-wennze-web-app-url
VITE_WENNZE_ANDROID_APP_URL=https://play.google.com/store/apps/details?id=com.wennze.app
VITE_WENNZE_IOS_APP_URL=https://apps.apple.com/us/app/wennze/id6755939537

VITE_GOSHOPPER_ANDROID_APP_URL=https://your-goshopper-android-download-url
VITE_GOSHOPPER_IOS_APP_URL=https://your-goshopper-ios-download-url

# Gmail SMTP Configuration (configured in Firebase CLI)
# Note: Set Gmail credentials using Firebase CLI:
# firebase functions:config:set gmail.email="your-email@gmail.com" gmail.password="your-app-password"
