#!/bin/bash

# Pre-commit hook to detect secrets before they're committed
# This script checks for common sensitive data patterns

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo "🔐 Running secret detection pre-commit hook..."

# Patterns to detect
SECRETS=(
    "AIzaSy[a-zA-Z0-9\-_]{35}"  # Firebase API Keys
    "AKIA[0-9A-Z]{16}"           # AWS Access Keys
    "-----BEGIN.*PRIVATE KEY-----" # Private keys
    "password\s*[:=]" # Password assignments
    "api_key\s*[:=]" # API key assignments
    "secret\s*[:=]"  # Secret assignments
    "udjqnnvbvizfbekt" # Known Gmail password (from conversation)
)

SENSITIVE_FILES=(
    "\.env"
    "credentials\.json"
    "google-services\.json"
    "GoogleService-Info\.plist"
    "\.runtimeconfig\.json"
)

# Check staged files
STAGED_FILES=$(git diff --cached --name-only)

FOUND_SECRETS=0

for file in $STAGED_FILES; do
    # Skip certain file types
    if [[ $file == *.lock ]] || [[ $file == *.log ]] || [[ $file == node_modules/* ]]; then
        continue
    fi

    # Check if file should never be committed
    for sensitive_pattern in "${SENSITIVE_FILES[@]}"; do
        if [[ $file =~ $sensitive_pattern ]]; then
            echo -e "${RED}❌ ERROR: Sensitive file detected: $file${NC}"
            echo "   This file should NOT be committed to git."
            FOUND_SECRETS=1
        fi
    done

    # Check file content for secrets
    for secret_pattern in "${SECRETS[@]}"; do
        if git diff --cached "$file" | grep -iE "$secret_pattern" > /dev/null; then
            echo -e "${RED}❌ WARNING: Potential secret detected in: $file${NC}"
            echo "   Pattern: $secret_pattern"
            git diff --cached "$file" | grep -iE -n "$secret_pattern" | head -3
            FOUND_SECRETS=1
        fi
    done
done

if [ $FOUND_SECRETS -eq 1 ]; then
    echo ""
    echo -e "${RED}⚠️  COMMIT BLOCKED: Potential secrets detected!${NC}"
    echo ""
    echo "Actions to take:"
    echo "1. Remove the sensitive data from staged files"
    echo "2. Add the file to .gitignore if it contains secrets"
    echo "3. Run: git reset HEAD <file> to unstage"
    echo "4. Edit the file to remove secrets"
    echo "5. Add to .gitignore"
    echo "6. Stage and commit again"
    echo ""
    echo "To bypass (NOT RECOMMENDED):"
    echo "git commit --no-verify"
    echo ""
    exit 1
fi

echo "✅ No secrets detected!"
exit 0
